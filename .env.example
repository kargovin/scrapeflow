# App
APP_ENV=development
DEBUG=true

# Postgres
DATABASE_URL=postgresql+asyncpg://scrapeflow:scrapeflow@postgres:5432/scrapeflow

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# NATS
NATS_URL=nats://nats:4222

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=scrapeflow
MINIO_SECRET_KEY=scrapeflow_secret
MINIO_BUCKET=scrapeflow-results
MINIO_SECURE=false

# Clerk (get these from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...  # backend JWT verification + API calls

# Rate limiting
RATE_LIMIT_RPM=60

# LLM Key Encryption
LLM_KEY_ENCRYPTION_KEY=your_fernet_key_here  # must be a valid Fernet key, e.g. generated via `Fernet.generate_key().decode()`
# LLM Worker
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_CONTENT_CHARS=50000
LLM_MAX_WORKERS = 3

# Cron job scheduling
SCHEDULE_MIN_INTERVAL_MINUTES=5  # minimum allowed interval for cron jobs, in minutes
