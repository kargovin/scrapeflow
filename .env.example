# App
APP_ENV=development
DEBUG=true

# Postgres
DATABASE_URL=postgresql+asyncpg://scrapeflow:scrapeflow@postgres:5432/scrapeflow

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# NATS
NATS_URL=nats://nats:4222

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=scrapeflow
MINIO_SECRET_KEY=scrapeflow_secret
MINIO_BUCKET=scrapeflow-results
MINIO_SECURE=false

# Clerk (get these from https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Rate limiting
RATE_LIMIT_RPM=60
